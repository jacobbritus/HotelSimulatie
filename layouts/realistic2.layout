<grid rows="7" columns="7">
    <label text="Hall" fill="true"/>
    <label text="Lobby" row="0" column="0" colSpan="4" />

    <label text="Empty" row="0" column="4" rowSpan="3" colSpan="3"/>

    <label text="Kamer" row="1" rowSpan="6" column="0" />
    <label text="Kamer" row="6" colSpan="6" column="1" />
    <label text="Kamer" row="1" rowSpan="2" column="3" />

    <label text="Kamer" row="3" colSpan="4" column="3" />

    <label text="Kamer" row="4" rowSpan="2" column="6" />


    <label text="Empty" row="6" column="0"/>
    <label text="Empty" row="6" column="6"/>
    <label text="Empty" row="3" column="6"/>

</grid>