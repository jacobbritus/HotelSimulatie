import javax.swing.*;
import java.awt.*;
import javax.swing.JSlider;

public class Screen extends JFrame {
    private final CardLayout cardLayout;
    private final JPanel mainPanel;

    public Screen() {
        setTitle("Hotel Simulator");
        setSize(900, 900);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setResizable(false);
        setLocationRelativeTo(null);

        //CardLayout toevoegen
        cardLayout = new CardLayout();
        mainPanel = new JPanel(cardLayout);

        //Panels toevoegen
        mainPanel.add(Title(), "title");
        mainPanel.add(Settings(), "settings");
        mainPanel.add(LayoutLoader(), "layout");
        add(mainPanel);
        setVisible(true);

        cardLayout.show(mainPanel, "title");
    }

    public JPanel Title(){ //Titel scherm
        JPanel panel = new JPanel();
        panel.setLayout(null);
        panel.setBackground(new Color(10, 30, 60)); //donkerblauw

        JLabel title = new JLabel("Hotel Simulator", SwingConstants.CENTER);
        title.setForeground(new Color(255, 230, 180)); //champagnekleur
        title.setFont(new Font("Times New Roman", Font.BOLD, 40));
        title.setBounds(300, 200, 300, 60);
        panel.add(title);

        Color gold = new Color(212, 175, 55);

        JButton start = new JButton("New Simulation");
        JButton settings = new JButton("Settings");
        JButton layout = new JButton("Load Layout");

        JButton[] buttons = new JButton[]{start, settings, layout};
        int y = 300;

        for (JButton b : buttons) {
            b.setBackground(gold);
            b.setForeground(Color.BLACK);
            b.setFont(new Font("Times New Roman", Font.BOLD, 22));
            b.setBounds(300, y, 300, 60);
            panel.add(b);
            y += 100;
        }

        settings.addActionListener(e -> cardLayout.show(mainPanel, "settings"));
        layout.addActionListener(e -> cardLayout.show(mainPanel, "layout"));

        return panel;
    }

    public JPanel Settings() { // Instellingen scherm
        JPanel panel = new JPanel();
        panel.setLayout(null);
        panel.setBackground(new Color(10, 30, 60));

        JLabel title = new JLabel("Settings");
        title.setForeground(new Color(255, 230, 180));
        title.setFont(new Font("Times New Roman", Font.BOLD, 40));
        title.setBounds(300, 50, 400, 60);
        panel.add(title);

        JLabel volume = new JLabel("Volume");
        volume.setForeground(Color.WHITE);
        volume.setFont(new Font("Times New Roman", Font.PLAIN, 20));
        volume.setBounds(100, 150, 200, 30);
        panel.add(volume);

        JSlider slider = new JSlider(0, 100, 50);
        slider.setBounds(300, 150, 200, 30);
        slider.setMajorTickSpacing(25);
        slider.setPaintTicks(true);
        slider.setPaintLabels(true);
        panel.add(slider);

        JCheckBox fullscreen = new JCheckBox("Fullscreen");
        fullscreen.setForeground(Color.WHITE);
        fullscreen.setOpaque(false);
        fullscreen.setFont(new Font("Times New Roman", Font.PLAIN, 20));
        fullscreen.setBounds(100, 260, 200, 30);
        panel.add(fullscreen);

        JButton back = new JButton("Back");
        back.setBackground(new Color(215, 175, 55));
        back.setForeground(Color.BLACK);
        back.setFont(new Font("Times New Roman", Font.BOLD, 20));
        back.setBounds(350, 400, 200, 60);
        back.addActionListener(e -> cardLayout.show(mainPanel, "title"));
        panel.add(back);

        return panel;
    }

    public JPanel LayoutLoader(){ // Layout Loader scherm
        JPanel panel = new JPanel();
        panel.setLayout(null);
        panel.setBackground(new Color(10, 30, 60));

        JLabel title = new JLabel("Layout Loader");
        title.setForeground(new Color(255, 230, 180));
        title.setFont(new Font("Times New Roman", Font.BOLD, 40));
        title.setBounds(300, 50, 400, 60);
        panel.add(title);

        JTextArea log = new JTextArea();
        log.setEditable(false);
        JScrollPane scroll = new JScrollPane(log);
        scroll.setBounds(100, 150, 700, 400);
        panel.add(scroll);

        JButton load = new JButton("Load Layout");
        load.setBackground(new Color(215, 175, 55));
        load.setForeground(Color.BLACK);
        load.setFont(new Font("Times New Roman", Font.BOLD, 20));
        load.setBounds(100, 600, 250, 60);

        load.addActionListener(e -> {
            JFileChooser chooser = new JFileChooser();
            int result = chooser.showOpenDialog(this);
            if (result == JFileChooser.APPROVE_OPTION) {
                log.append("Loaded: " + chooser.getSelectedFile().getName() + "\n");
            }
        });

        panel.add(load);

        JButton back = new JButton("Back");
        back.setBackground(new Color(215, 175, 55));
        back.setForeground(Color.BLACK);
        back.setFont(new Font("Times New Roman", Font.BOLD, 20));
        back.setBounds(550, 600, 250, 60);
        back.addActionListener(e -> cardLayout.show(mainPanel, "title"));
        panel.add(back);
        
        return panel;
    }

    public static void main(String[] args) {
        new Screen();
    }
}
